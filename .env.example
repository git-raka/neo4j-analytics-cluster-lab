NEO4J_IMAGE=neo4j:2026.02.3-enterprise
NEO4J_PASSWORD=change-this-password
ADVERTISED_HOST=localhost
USER_ID=1000
GROUP_ID=1000

TX1_HTTP_PORT=17474
TX1_BOLT_PORT=17687
TX2_HTTP_PORT=17475
TX2_BOLT_PORT=17688
TX3_HTTP_PORT=17476
TX3_BOLT_PORT=17689
ANALYTICS1_HTTP_PORT=17477
ANALYTICS1_BOLT_PORT=17690
ANALYTICS2_HTTP_PORT=17478
ANALYTICS2_BOLT_PORT=17691

TX_HEAP=512M
TX_PAGECACHE=256M
ANALYTICS_HEAP=1G
ANALYTICS_PAGECACHE=512M

# Leave blank to run GDS in Community mode on the analytics nodes.
# Set to /licenses/gds after placing your GDS Enterprise license file in ./licenses/gds
GDS_LICENSE_FILE=
